# .env.ai-providers.example
#
# New environment variables introduced by the AI provider integration
# (lib/providers/replicate-ai-provider.ts, fal-ai-provider.ts,
# suno-ai-provider.ts, lyrics-enhancer.ts). Copy the relevant lines into
# your existing .env.local — this file does not replace it.
#
# None of these are required for the app/worker to BOOT. They're checked
# lazily, the first time a generation actually calls out to that specific
# provider — see each provider's requireXxx() function. Until configured,
# attempting a generation with that provider selected fails with a clear
# InfrastructureError rather than a silent no-op or a confusing low-level
# fetch error.

# Which registered provider answers AIProviderFactory.getProvider()'s
# 'default' lookup (the only name process-song-generation.use-case.ts ever
# asks for). One of: replicate | fal | suno. Defaults to "replicate" if unset.
AI_PROVIDER=replicate

# --- Replicate (MusicGen + Bark) ---
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- FAL.ai (MusicGen / Stable Audio / AudioLDM2) ---
# https://fal.ai/dashboard/keys
FAL_KEY=
# Which FAL-hosted music model to use. One of: musicgen | stable-audio | audioldm2
# Defaults to "musicgen" if unset.
FAL_MUSIC_MODEL=musicgen

# --- Suno (self-hosted via Docker) ---
# Base URL of your self-hosted Suno-compatible generation service
# (e.g. http://localhost:3001 in local dev, or the in-cluster service DNS
# name once it's added as a sibling container alongside the worker).
SUNO_SERVICE_URL=
# Optional — only needed if your self-hosted service enforces its own auth.
SUNO_SERVICE_API_KEY=

# --- Lyrics enhancement (shared by all three providers' enhanceLyrics()) ---
# Which backend to prefer when BOTH keys below are set. One of:
# claude-haiku | gpt-4o-mini. If only one key is set, that one is used
# regardless of this preference. If neither key is set, enhanceLyrics()
# returns the input lyrics unchanged rather than failing the generation.
LYRICS_ENHANCER_BACKEND=claude-haiku
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
