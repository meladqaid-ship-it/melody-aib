# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/melody_ai

# ─── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.netlify.app
NEXT_PUBLIC_APP_URL=https://your-backend.onrender.com

# ─── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── Email (SMTP) ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_...
SMTP_FROM=noreply@yourdomain.com

# ─── S3-Compatible Storage ───────────────────────────────────────────────────────
S3_BUCKET=melody-ai-audio
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_ENDPOINT=https://... # optional, for non-AWS providers (Cloudflare R2, etc.)

# ─── AI Providers ────────────────────────────────────────────────────────────────
REPLICATE_API_TOKEN=r8_...
FAL_KEY=...
SUNO_API_URL=http://localhost:3002
ANTHROPIC_API_KEY=sk-ant-...

# ─── Worker ─────────────────────────────────────────────────────────────────────
AI_WORKER_CONCURRENCY=3

# ─── Misc ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
